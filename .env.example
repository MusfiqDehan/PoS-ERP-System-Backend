# Backend environment template.
# Copy this file to .env.local for local development or to .env.prod for production.

# ── Django core ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
PORT=8002
# Local dev tooling (config.settings.local): OpenAPI docs at /api/v1/docs/,
# debug toolbar at /__debug__/, Silk profiler at /silk/ (DEBUG=true only).
# First-time Silk setup on host: python manage.py migrate_schemas --shared

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Production: point at PgBouncer (session pool). Migrations use DIRECT_DATABASE_URL.
DATABASE_URL=postgresql://sortorium_user:sortorium_password@pgbouncer:6432/sortorium_db
DIRECT_DATABASE_URL=postgresql://sortorium_user:sortorium_password@db:5432/sortorium_db
USE_PGBOUNCER=1
DB_CONN_MAX_AGE=0
BACKUP_DIR=/var/backups/sortorium-postgres
DB_NAME=sortorium_db
DB_USER=sortorium_user
DB_PASSWORD=sortorium_password
DB_HOST=localhost
DB_PORT=5432

# ── Redis / Celery ───────────────────────────────────────────────────────────
# Host machine (outside Docker): use port 6380 — mapped from container 6379.
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0
REDIS_CACHE_URL=redis://localhost:6380/2
# Docker Compose overrides these to redis://redis:6379/... for backend/celery services.
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=false

# ── Multi-tenancy ────────────────────────────────────────────────────────────
PUBLIC_DOMAIN=localhost
TENANT_BASE_DOMAIN=localhost
TENANT_ROOT_DOMAIN=localhost
FRONTEND_BASE_URL=http://localhost:3002
PUBLIC_FRONTEND_URL=http://localhost:3003
# URL of THIS backend's public API — used for SSLCommerz payment gateway callbacks
# (success/fail/cancel/ipn). Must be reachable by the payment gateway server.
# Local: http://localhost:8002
# Production: https://api.yourdomain.com  (single fixed URL, NOT tenant-specific)
BACKEND_BASE_URL=http://localhost:8002
TENANT_FRONTEND_BASE_DOMAIN=localhost
TENANT_FRONTEND_SCHEME=http
TENANT_FRONTEND_PORT=5174
TENANT_POST_LOGIN_PATH=/dashboard
TENANT_ONBOARDING_LINKS_PUBLIC=false
SHOW_PUBLIC_IF_NO_TENANT_FOUND=true
AUTO_CREATE_DEFAULT_TENANT=true
DEFAULT_TENANT_SCHEMA=sortorium_local
DEFAULT_TENANT_NAME=Local sortorium
DEFAULT_TENANT_SLUG=local-sortorium
DEFAULT_TENANT_CODE=LOCAL
DEFAULT_TENANT_DOMAINS=local-sortorium.localhost

# ── Superadmin ───────────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me
SUPERADMIN_SCHEMA=public

# ── Device integration ───────────────────────────────────────────────────────
SORTORIUM_DEVICE_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_TIMEOUT=15

# ── Optional tuning ──────────────────────────────────────────────────────────
WEB_CONCURRENCY=3
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50
CONN_MAX_AGE=600

# ── DRF Rate limiting ────────────────────────────────────────────────────────
# Short-window burst guards (blocks rapid automated hits / scraping)
# Tighten these in production. Format: <count>/<period>  e.g. 20/min, 5/sec
THROTTLE_BURST_ANON=20/min
THROTTLE_BURST_USER=60/min
# Hourly volume caps (sustained traffic ceiling)
THROTTLE_SUSTAINED_ANON=500/hour
THROTTLE_SUSTAINED_USER=2000/hour