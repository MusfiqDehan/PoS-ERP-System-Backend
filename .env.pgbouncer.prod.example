# PgBouncer configuration for production Docker Compose.
# Copy to .env.pgbouncer.prod — loaded by pgbouncer service only.
# DATABASE_URL must point at PostgreSQL directly (db:5432), NOT PgBouncer.
# Use the same POSTGRES_* credentials as .env.prod (URL-encode special chars in password).

DATABASE_URL=postgres://sortorium_user:sortorium_password@db:5432/sortorium_db
LISTEN_PORT=6432
POOL_MODE=session
MAX_CLIENT_CONN=200
DEFAULT_POOL_SIZE=20
AUTH_TYPE=scram-sha-256
